---
---

<section class='relative w-full py-16 md:py-20'>
  <h2 class='text-xl font-bold mb-8 text-foreground sm:text-3xl text-center'>
    Próximos <span class='gradient-text'>eventos</span>
  </h2>
  <div class='flex flex-col gap-3 max-w-md'>
    <a
      href='https://luma.com/hacktandil'
      target='_blank'
      rel='noopener noreferrer'
      class='group flex items-center justify-between gap-6 rounded-xl border border-border bg-muted/40 px-6 py-5 hover:border-accent/40 hover:bg-muted/60 transition-all duration-200'
    >
      <div class='flex items-center gap-4'>
        <img src='/sponsors/hacktandil.png' alt='HackTandil' class='h-10 w-auto rounded-lg opacity-80 group-hover:opacity-100 transition-opacity' />
        <div>
          <p class='font-semibold text-foreground text-sm'>HackTandil</p>
          <p class='text-xs text-foreground-muted'>Ver próximos eventos</p>
        </div>
      </div>
      <svg width='18' height='18' viewBox='0 0 24 24' fill='none' class='text-foreground-muted group-hover:text-accent group-hover:translate-x-1 transition-all duration-200 shrink-0'>
        <path stroke='currentColor' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M5 12h14M13 6l6 6-6 6' />
      </svg>
    </a>
    <a
      href='https://luma.com/nodoserrano'
      target='_blank'
      rel='noopener noreferrer'
      class='group flex items-center justify-between gap-6 rounded-xl border border-border bg-muted/40 px-6 py-5 hover:border-accent/40 hover:bg-muted/60 transition-all duration-200'
    >
      <div class='flex items-center gap-4'>
        <div class='h-10 w-10 rounded-lg bg-muted/60 flex items-center justify-center opacity-80 group-hover:opacity-100 transition-opacity shrink-0'>
          <svg width='20' height='20' viewBox='0 0 24 24' fill='none' class='text-foreground-muted'>
            <rect x='3' y='4' width='18' height='18' rx='2' stroke='currentColor' stroke-width='1.5'/>
            <path d='M16 2v4M8 2v4M3 10h18' stroke='currentColor' stroke-width='1.5' stroke-linecap='round'/>
          </svg>
        </div>
        <div>
          <p class='font-semibold text-foreground text-sm'>Nodo Serrano</p>
          <p class='text-xs text-foreground-muted'>Ver próximos eventos</p>
        </div>
      </div>
      <svg width='18' height='18' viewBox='0 0 24 24' fill='none' class='text-foreground-muted group-hover:text-accent group-hover:translate-x-1 transition-all duration-200 shrink-0'>
        <path stroke='currentColor' stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M5 12h14M13 6l6 6-6 6' />
      </svg>
    </a>
  </div>
</section>
